# React Router (SPA) no Apache/Amen: serve ficheiros/pastas reais; tudo o resto
# cai no index.html para o router do lado do cliente tratar (sem 404 em /u/x etc).
Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ index.html [L]
