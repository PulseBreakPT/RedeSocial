# ─── Lusorae .gitignore ─────────────────────────────────────────────────────
# Single source of truth — do not append duplicates. Run a security audit if
# you find any secret patterns committed (see /app/DEPLOY.md).

# IDE and editors
.idea/
.vscode/
*.swp
*.swo

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build artefacts
/build
build/
dist/
/out
/.next
next-env.d.ts
*.tsbuildinfo

# Testing & coverage
/coverage
coverage/
.pytest_cache/
.coverage
.tox/
htmlcov/

# ─── SECRETS & CREDENTIALS ──────────────────────────────────────────────────
# Never commit .env files. .env.example is the safe-to-commit template.
.env
.env.*
*.env
!.env.example
!**/.env.example

# Keys, certs, tokens, credentials of any shape
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
*.jks
*.keystore
*.gpg
*.asc
credentials.json
*credentials.json
*token.json*
.credentials
secrets.json
*.secrets

# Cloud provider credential files
.aws/
.gcp/
gcp-key.json
service-account*.json
firebase-adminsdk*.json

# Test credentials & local memory
memory/test_credentials.md

# Logs and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
h1h4_test_output.log

# System files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.python-version

# Dev tooling
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac
.cache/

# Deployment
.vercel
.netlify

# Data / archives (large or sensitive)
agenthub/agents/youtube/db
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Mobile development
android-sdk/frontend/node_modules/.cache/default-development/5.pack
